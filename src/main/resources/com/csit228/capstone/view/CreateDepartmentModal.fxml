<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="527.0" prefWidth="415.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.csit228.capstone.controller.CreateDepartmentModalController">
   <children>
      <AnchorPane layoutY="-4.0" prefHeight="99.0" prefWidth="415.0" style="-fx-background-color: #7a1e1f;">
         <children>
            <Label fx:id="labelDepartment" graphicTextGap="0.0" layoutX="29.0" layoutY="43.0" prefHeight="43.0" prefWidth="351.0" text="Create Department" textFill="WHITE">
               <font>
                  <Font name="Georgia Bold Italic" size="25.0" />
               </font>
            </Label>
            <Button fx:id="buttonClose" layoutX="357.0" layoutY="34.0" mnemonicParsing="false" onAction="#onClickedButtonClose" prefHeight="31.0" prefWidth="33.0" style="-fx-background-radius: 15;" styleClass="button-createTicket" text="X" />
            <Label layoutX="28.0" layoutY="31.0" text="LET'S GET STARTED" textFill="WHITE">
               <font>
                  <Font name="Times New Roman" size="13.0" />
               </font>
            </Label>
         </children>
      </AnchorPane>
      <Line endX="251.5" layoutX="131.0" layoutY="192.0" startX="-100.0" stroke="#808080" />
      <Label layoutX="31.0" layoutY="115.0" text="DEPARTMENT NAME::" textFill="#686868">
         <font>
            <Font name="Times New Roman" size="13.0" />
         </font>
      </Label>
      <Label layoutX="30.0" layoutY="210.0" text="DESCRIPTION::" textFill="#686868">
         <font>
            <Font name="Times New Roman" size="13.0" />
         </font>
      </Label>
      <Button fx:id="buttonCancel" layoutX="126.0" layoutY="473.0" mnemonicParsing="false" onAction="#onClickedCancel" prefHeight="35.0" prefWidth="121.0" style="-fx-background-radius: 15;" styleClass="button-cancel" text="Cancel" />
      <Button fx:id="buttonCreateDepartment" layoutX="264.0" layoutY="473.0" mnemonicParsing="false" onAction="#onClickedCreateDepartment" prefHeight="35.0" prefWidth="121.0" style="-fx-background-radius: 15;" styleClass="button-createTicket" text="Add Job" />
      <Line endX="251.5" layoutX="131.0" layoutY="451.0" startX="-100.0" stroke="#808080" />
      <TextField fx:id="textfieldTicketTitle" layoutX="31.0" layoutY="138.0" prefHeight="35.0" prefWidth="354.0" promptText="eg. Research &amp; Design..." />
      <TextArea fx:id="textAreaTicketDesc" layoutX="28.0" layoutY="236.0" prefHeight="197.0" prefWidth="354.0" promptText="Describe this department.." />
   </children>
</AnchorPane>
