<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="410.0" prefWidth="415.0" style="-fx-background-color: #f5f0e7;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.csit228.capstone.controller.CreateJobModalController">
   <children>
      <AnchorPane layoutY="-4.0" prefHeight="99.0" prefWidth="415.0" style="-fx-background-color: #444444;">
         <children>
            <Label fx:id="labelDepartment" graphicTextGap="0.0" layoutX="29.0" layoutY="43.0" prefHeight="43.0" prefWidth="351.0" text="Name of Department" textFill="WHITE">
               <font>
                  <Font name="Georgia Bold" size="25.0" />
               </font>
            </Label>
            <Button fx:id="buttonClose" layoutX="357.0" layoutY="34.0" mnemonicParsing="false" onAction="#onClickClose" prefHeight="31.0" prefWidth="33.0" style="-fx-background-radius: 15;" styleClass="button-createTicket" text="X" />
            <Label layoutX="28.0" layoutY="31.0" text="CREATE POSITION FOR::" textFill="WHITE">
               <font>
                  <Font name="Times New Roman" size="13.0" />
               </font>
            </Label>
         </children>
      </AnchorPane>
      <Line endX="251.5" layoutX="131.0" layoutY="222.0" startX="-100.0" stroke="#808080" />
      <Label layoutX="31.0" layoutY="115.0" text="CHOOSE FROM EXISTING::" textFill="#686868">
         <font>
            <Font name="Times New Roman" size="13.0" />
         </font>
      </Label>
      <ComboBox fx:id="comboboxJob" layoutX="29.0" layoutY="143.0" onAction="#onSelectChange" prefHeight="36.0" prefWidth="356.0" promptText="Create New Job" />
      <TextField fx:id="textfieldJob" layoutX="30.0" layoutY="262.0" prefHeight="35.0" prefWidth="354.0" promptText="eg. Graphic Designer.." />
      <Label layoutX="30.0" layoutY="240.0" text="POSITION NAME::" textFill="#686868">
         <font>
            <Font name="Times New Roman" size="13.0" />
         </font>
      </Label>
      <Button fx:id="buttonCancel" layoutX="126.0" layoutY="343.0" mnemonicParsing="false" onAction="#onClickedCancel" prefHeight="35.0" prefWidth="121.0" style="-fx-background-radius: 15;" styleClass="button-cancel" text="Cancel" />
      <Button fx:id="buttonAddJob" layoutX="264.0" layoutY="343.0" mnemonicParsing="false" onAction="#onClickCreateJob" prefHeight="35.0" prefWidth="121.0" style="-fx-background-radius: 15;" styleClass="button-createTicket" text="Add Job" />
      <Line endX="251.5" layoutX="131.0" layoutY="321.0" startX="-100.0" stroke="#808080" />
      <Label layoutX="31.0" layoutY="190.0" prefHeight="15.0" prefWidth="356.0" text="Select an existing position to be added to this department " textFill="#686868">
         <font>
            <Font name="Times New Roman" size="13.0" />
         </font>
      </Label>
   </children>
</AnchorPane>
