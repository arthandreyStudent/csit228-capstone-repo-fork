<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<HBox alignment="CENTER_LEFT" prefHeight="758.0" prefWidth="1500.0" style="-fx-background-color: #f5f0e7;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.csit228.capstone.controller.TicketEditorController">

    <children>
        <VBox prefHeight="758.0" prefWidth="250.0" spacing="18.0" style="-fx-background-color: #7a1e1f;">
            <padding>
                <Insets bottom="18.0" left="16.0" right="16.0" top="22.0" />
            </padding>

            <children>
                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <children>
                        <Circle fill="white" radius="22.0" />
                        <Label style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" text="TIX.org" />
                    </children>
                </HBox>

                <Label style="-fx-text-fill: #bcd2ff; -fx-font-size: 11px; -fx-font-weight: bold;" text="EDITOR">
                    <VBox.margin>
                        <Insets left="20.0" top="30.0" />
                    </VBox.margin>
                </Label>

                <HBox alignment="CENTER_LEFT" onMouseClicked="#onClickedDashboard" prefHeight="42.0" prefWidth="218.0" spacing="12.0" style="-fx-background-color: #5b1617; -fx-background-radius: 10;">
                    <padding>
                        <Insets left="18.0" />
                    </padding>
                    <children>
                        <Label style="-fx-text-fill: white; -fx-font-size: 17px; -fx-font-weight: bold;" text="⌂" />
                        <Label style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" text="Dashboard" />
                    </children>
                </HBox>

                <Region VBox.vgrow="ALWAYS" />

                <VBox prefHeight="120.0" prefWidth="218.0" spacing="12.0" style="-fx-background-color: #5b1617; -fx-background-radius: 12;">
                    <padding>
                        <Insets bottom="14.0" left="14.0" right="14.0" top="16.0" />
                    </padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <StackPane prefHeight="40.0" prefWidth="40.0">
                                    <children>
                                        <Circle fill="#8b642b" radius="20.0" />
                                        <Label fx:id="profileInitialsLabel" style="-fx-text-fill: #ff9900; -fx-font-size: 12px; -fx-font-weight: bold;" text="NA" />
                                    </children>
                                </StackPane>

                                <VBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label fx:id="profileNameLabel" style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;" text="Editor User" />
                                        <Label fx:id="profileRoleLabel" style="-fx-text-fill: #ff9900; -fx-font-size: 10px; -fx-font-weight: bold;" text="EDITOR" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox spacing="8.0">
                            <children>
                                <Button fx:id="profileButton" onAction="#onClickedProfile" prefHeight="30.0" prefWidth="82.0" style="-fx-background-color: #e6f0ff; -fx-background-radius: 18; -fx-text-fill: #1b2b5f; -fx-font-size: 12px; -fx-font-weight: bold;" text="Profile" />
                                <Button fx:id="buttonLogout" onAction="#onClickedLogout" prefHeight="30.0" prefWidth="96.0" style="-fx-background-color: #ef4c56; -fx-background-radius: 18; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;" text="Logout" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>

        <AnchorPane fx:id="mainContentPane" prefHeight="758.0" prefWidth="1263.0" style="-fx-background-color: #f5f0e7;">

            <children>
                <VBox layoutX="20.0" layoutY="20.0" spacing="2.0">
                    <children>
                        <Label style="-fx-text-fill: #9faad2; -fx-font-size: 12px;" text="Pages / Dashboard" />
                        <Label style="-fx-text-fill: #1c2b63; -fx-font-size: 28px; -fx-font-weight: bold;" text="Dashboard" />
                    </children>
                </VBox>

                <HBox layoutX="25.0" layoutY="90.0" spacing="15.0">
                    <children>
                        <AnchorPane prefHeight="92.0" prefWidth="285.0" style="-fx-background-color: #444444; -fx-background-radius: 14;">
                            <children>
                                <Label fx:id="awaitingReviewLabel" layoutX="20.0" layoutY="37.0" style="-fx-text-fill: white; -fx-font-size: 28;" text="0" />
                        <Label layoutX="20.0" layoutY="18.0" text="OPEN TICKETS::" textFill="WHITE">
                           <font>
                              <Font name="Georgia Bold" size="11.0" />
                           </font>
                        </Label>
                            </children>
                        </AnchorPane>

                        <AnchorPane prefHeight="92.0" prefWidth="285.0" style="-fx-background-color: #444444; -fx-background-radius: 14;">
                            <children>
                                <Label fx:id="inProgressLabel" layoutX="21.0" layoutY="35.0" style="-fx-text-fill: white; -fx-font-size: 28;" text="0" />
                        <Label layoutX="19.0" layoutY="17.0" text="IN PROGRESS::" textFill="WHITE">
                           <font>
                              <Font name="Georgia Bold" size="11.0" />
                           </font>
                        </Label>
                            </children>
                        </AnchorPane>

                        <AnchorPane prefHeight="92.0" prefWidth="285.0" style="-fx-background-color: #444444; -fx-background-radius: 14;">
                            <children>
                                <Label fx:id="approvedTodayLabel" layoutX="16.0" layoutY="35.0" style="-fx-text-fill: white; -fx-font-size: 28;" text="0" />
                        <Label layoutX="18.0" layoutY="18.0" text="APPROVED TODAY::" textFill="WHITE">
                           <font>
                              <Font name="Georgia Bold" size="11.0" />
                           </font>
                        </Label>
                            </children>
                        </AnchorPane>

                        <AnchorPane prefHeight="92.0" prefWidth="319.0" style="-fx-background-color: #444444; -fx-background-radius: 14;">
                            <children>
                                <Label fx:id="sentBackLabel" layoutX="20.0" layoutY="35.0" style="-fx-text-fill: white; -fx-font-size: 28;" text="0" />
                        <Label layoutX="21.0" layoutY="18.0" text="SENT BACK::" textFill="WHITE">
                           <font>
                              <Font name="Georgia Bold" size="11.0" />
                           </font>
                        </Label>
                            </children>
                        </AnchorPane>
                    </children>
                </HBox>

                <AnchorPane layoutX="25.0" layoutY="205.0" prefHeight="535.0" prefWidth="918.0" style="-fx-background-color: white; -fx-background-radius: 16;">
                    <children>
                        <Label layoutX="18.0" layoutY="18.0" style="-fx-text-fill: #1c2b63; -fx-font-size: 18px; -fx-font-weight: bold;" text="Review Queue" />

                        <ComboBox fx:id="deadlineSortComboBox" layoutX="545.0" layoutY="18.0" onAction="#onDeadlineSortChanged" prefHeight="28.0" prefWidth="170.0" promptText="Sort Deadline" style="-fx-background-color: white; -fx-border-color: #dfe7f5; -fx-border-radius: 18; -fx-background-radius: 18; -fx-font-size: 11px;" />

                        <Button fx:id="createTicketButton" layoutX="720.0" layoutY="18.0" onAction="#handleCreateTicket" prefHeight="28.0" prefWidth="130.0" style="-fx-background-color: #4bcc8a; -fx-background-radius: 18; -fx-text-fill: white; -fx-font-size: 11px; -fx-font-weight: bold;" text="+ Create Ticket" />

                        <HBox layoutX="432.0" layoutY="56.0" spacing="8.0">
                            <children>
                                <Button fx:id="allFilterButton" onAction="#showAllTickets" prefHeight="28.0" prefWidth="50.0" style="-fx-background-color: #1c2b63; -fx-background-radius: 18; -fx-text-fill: white; -fx-font-size: 11px; -fx-font-weight: bold;" text="All" />
                                <Button fx:id="openFilterButton" onAction="#showOpenTickets" prefHeight="28.0" prefWidth="64.0" style="-fx-background-color: white; -fx-border-color: #dfe7f5; -fx-border-radius: 18; -fx-background-radius: 18; -fx-text-fill: #9faad2; -fx-font-size: 11px; -fx-font-weight: bold;" text="Open" />
                                <Button fx:id="inProgressFilterButton" onAction="#showInProgressTickets" prefHeight="28.0" prefWidth="90.0" style="-fx-background-color: white; -fx-border-color: #dfe7f5; -fx-border-radius: 18; -fx-background-radius: 18; -fx-text-fill: #9faad2; -fx-font-size: 11px; -fx-font-weight: bold;" text="In Progress" />
                                <Button fx:id="completedFilterButton" onAction="#showCompletedTickets" prefHeight="28.0" prefWidth="104.0" style="-fx-background-color: white; -fx-border-color: #dfe7f5; -fx-border-radius: 18; -fx-background-radius: 18; -fx-text-fill: #9faad2; -fx-font-size: 11px; -fx-font-weight: bold;" text="To Be Reviewed" />
                                <Button fx:id="resolvedFilterButton" onAction="#showResolvedTickets" prefHeight="28.0" prefWidth="78.0" style="-fx-background-color: white; -fx-border-color: #dfe7f5; -fx-border-radius: 18; -fx-background-radius: 18; -fx-text-fill: #9faad2; -fx-font-size: 11px; -fx-font-weight: bold;" text="Resolved" />
                            </children>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" layoutX="25.0" layoutY="102.0" prefHeight="30.0" prefWidth="830.0">
                            <children>
                                <Label prefWidth="370.0" style="-fx-text-fill: #9faad2; -fx-font-size: 10px; -fx-font-weight: bold;" text="TICKET DETAILS" />
                                <Label prefWidth="95.0" style="-fx-text-fill: #9faad2; -fx-font-size: 10px; -fx-font-weight: bold;" text="STATUS" />
                                <Label prefWidth="85.0" style="-fx-text-fill: #9faad2; -fx-font-size: 10px; -fx-font-weight: bold;" text="PRIORITY" />
                                <Label prefWidth="170.0" style="-fx-text-fill: #9faad2; -fx-font-size: 10px; -fx-font-weight: bold;" text="DEADLINE" />

                            </children>
                        </HBox>

                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" layoutX="25.0" layoutY="138.0" prefHeight="395.0" prefWidth="832.0" style="-fx-background-color: transparent; -fx-background: transparent;" vbarPolicy="AS_NEEDED">
                            <content>
                                <VBox fx:id="reviewQueueBox" prefWidth="830.0" spacing="0.0" style="-fx-background-color: transparent;" />
                            </content>
                        </ScrollPane>
      
                      <HBox alignment="CENTER_LEFT" layoutX="179.0" layoutY="14.0" prefHeight="36.0" prefWidth="280.0" spacing="8.0" style="-fx-background-color: white; -fx-background-radius: 24;">
                          <padding>
                              <Insets left="14.0" right="10.0" />
                          </padding>
                          <children>
                              <Label style="-fx-text-fill: #9faad2; -fx-font-size: 16px;" text="⌕" />
                          </children>
                      </HBox>
                        <TextField fx:id="searchField" layoutX="52.0" layoutY="57.0" prefWidth="220.0" promptText="Search tickets..." style="-fx-background-color: transparent; -fx-text-fill: #1c2b63; -fx-prompt-text-fill: #9faad2;" />
                    </children>
                </AnchorPane>

                <AnchorPane layoutX="960.0" layoutY="205.0" prefHeight="535.0" prefWidth="285.0" style="-fx-background-color: white; -fx-background-radius: 16;">
                    <children>
                  <Button fx:id="submitForm" layoutX="153.0" layoutY="221.0" mnemonicParsing="false" onAction="#createAnnouncement" prefHeight="34.0" prefWidth="109.0" style="-fx-background-radius: 20; -fx-background-color: #7a1e1f;" text="Publish" textFill="WHITE">
                     <font>
                        <Font name="Georgia Bold Italic" size="13.0" />
                     </font></Button>
                  <TextField fx:id="titleField" layoutX="24.0" layoutY="71.0" prefHeight="26.0" prefWidth="238.0" promptText="eg. Meeting Later at...">
                     <font>
                        <Font size="11.0" />
                     </font></TextField>
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" layoutX="18.0" layoutY="321.0" prefHeight="200.0" prefWidth="248.0" style="-fx-background-color: transparent; -fx-background: transparent;" vbarPolicy="AS_NEEDED">
                            <content>
                                <VBox fx:id="notificationPane" prefWidth="248.0" spacing="10.0" style="-fx-background-color: transparent;" />
                            </content>
                        </ScrollPane>
                  <Label layoutX="24.0" layoutY="25.0" text="Create Announcement">
                     <font>
                        <Font name="Georgia Bold" size="16.0" />
                     </font>
                  </Label>
                  <Label layoutX="24.0" layoutY="53.0" text="TITLE::" textFill="#757575">
                     <font>
                        <Font name="Georgia Bold Italic" size="11.0" />
                     </font>
                  </Label>
                  <Label layoutX="24.0" layoutY="109.0" text="DESCRIPTION::" textFill="#757575">
                     <font>
                        <Font name="Georgia Bold Italic" size="11.0" />
                     </font>
                  </Label>
                  <Label layoutX="24.0" layoutY="291.0" text="Notifications::">
                     <font>
                        <Font name="Georgia Bold" size="16.0" />
                     </font>
                  </Label>
                  <TextArea fx:id="descriptionTextField" layoutX="25.0" layoutY="128.0" prefHeight="84.0" prefWidth="238.0" promptText="eg. The meeting will be..." />
                    </children>
                </AnchorPane>
            </children>
        </AnchorPane>
    </children>
</HBox>
